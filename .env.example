# ---------------------------------------------------------------------------
# Applaud environment (example — copy to .env and fill in)
# ---------------------------------------------------------------------------

# Postgres connection string (Neon on Vercel, or any Postgres).
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# next-auth (Auth.js) v5 — generate with: npx auth secret
AUTH_SECRET="change-me"
AUTH_URL="http://localhost:3000"

# Milestone cron — sent as `Authorization: Bearer <CRON_SECRET>`.
CRON_SECRET="change-me"

# Vercel Blob — stores recognition photos/GIFs. Create a Blob store in the
# Vercel dashboard (Storage → Blob) and connect it to the project; Vercel then
# injects this automatically. For local dev, run `vercel env pull` to fetch it.
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxx"
