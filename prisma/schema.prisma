// Applaud — employee recognition & rewards platform.
// Conventions: cuid() IDs, string roles, Site (not Center),
// append-only RewardLedger as the wallet source of truth.

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ---------- Org & people ----------

model Site {
  id        String   @id @default(cuid())
  name      String
  code      String   @unique // short prefix, e.g. "MAH"
  timezone  String   @default("Europe/Dublin")
  active    Boolean  @default(true)
  users     User[]
  createdAt DateTime @default(now())
}

model User {
  id        String    @id @default(cuid())
  email     String    @unique
  name      String
  avatarUrl String?
  jobTitle  String?
  role      String    @default("staff") // "staff" | "manager" | "admin"
  siteId    String
  site      Site      @relation(fields: [siteId], references: [id])
  managerId String?
  manager   User?     @relation("Reports", fields: [managerId], references: [id])
  reports   User[]    @relation("Reports")
  hireDate  DateTime?
  birthday  DateTime? // store full date; celebrate on month/day
  active    Boolean   @default(true)
  createdAt DateTime  @default(now())

  // Cached wallet balance. Always written inside the same transaction as the
  // ledger row; RewardLedger SUM remains the source of truth (recompute action exists).
  walletBalance Int @default(0)

  sentRecognitions     Recognition[]          @relation("Sender")
  receivedRecognitions RecognitionRecipient[]
  reactions            Reaction[]
  comments             Comment[]
  nominationsMade      Nomination[]           @relation("Nominator")
  nominationsReceived  Nomination[]           @relation("Nominee")
  ledger               RewardLedger[]
  redemptions          Redemption[]
  celebrations         Celebration[]

  // next-auth adapter relations
  accounts Account[]
  sessions Session[]
}

// ---------- Recognition ----------

model Value {
  id          String        @id @default(cuid())
  name        String
  description String?
  icon        String? // lucide icon name
  color       String? // hex or token
  order       Int           @default(0)
  active      Boolean       @default(true)
  recognitions Recognition[]
}

model Recognition {
  id         String   @id @default(cuid())
  senderId   String
  sender     User     @relation("Sender", fields: [senderId], references: [id])
  valueId    String?
  value      Value?   @relation(fields: [valueId], references: [id])
  message    String
  visibility String   @default("public") // "public" | "private"
  system     Boolean  @default(false) // true = auto/milestone post
  createdAt  DateTime @default(now())

  recipients RecognitionRecipient[]
  reactions  Reaction[]
  comments   Comment[]

  @@index([createdAt])
}

model RecognitionRecipient {
  id            String      @id @default(cuid())
  recognitionId String
  recognition   Recognition @relation(fields: [recognitionId], references: [id], onDelete: Cascade)
  userId        String
  user          User        @relation(fields: [userId], references: [id])
  points        Int         @default(0) // redeemable points granted to this recipient

  @@unique([recognitionId, userId])
}

model Reaction {
  id            String      @id @default(cuid())
  recognitionId String
  recognition   Recognition @relation(fields: [recognitionId], references: [id], onDelete: Cascade)
  userId        String
  user          User        @relation(fields: [userId], references: [id])
  emoji         String
  createdAt     DateTime    @default(now())

  @@unique([recognitionId, userId, emoji])
}

model Comment {
  id            String      @id @default(cuid())
  recognitionId String
  recognition   Recognition @relation(fields: [recognitionId], references: [id], onDelete: Cascade)
  userId        String
  user          User        @relation(fields: [userId], references: [id])
  body          String
  createdAt     DateTime    @default(now())
}

// ---------- Nomination awards ----------

model AwardProgram {
  id               String       @id @default(cuid())
  name             String
  description      String?
  points           Int          @default(0) // awarded to winner on approval
  cadence          String? // "monthly" | "quarterly" | null (ad hoc)
  requiresApproval Boolean      @default(true)
  active           Boolean      @default(true)
  nominations      Nomination[]
}

model Nomination {
  id            String       @id @default(cuid())
  programId     String
  program       AwardProgram @relation(fields: [programId], references: [id])
  nominatorId   String
  nominator     User         @relation("Nominator", fields: [nominatorId], references: [id])
  nomineeId     String
  nominee       User         @relation("Nominee", fields: [nomineeId], references: [id])
  justification String
  status        String       @default("pending") // pending | approved | rejected
  reviewedById  String?
  reviewedAt    DateTime?
  pointsAwarded Int          @default(0)
  createdAt     DateTime     @default(now())
}

// ---------- Rewards & wallet ----------

model Reward {
  id          String       @id @default(cuid())
  name        String
  description String?
  imageUrl    String?
  category    String?
  pointsCost  Int
  type        String       @default("internal") // "internal" | "giftcard" (future adapter)
  fulfilment  String       @default("manual") // "manual" | "auto"
  stock       Int? // null = unlimited
  siteId      String? // null = all sites
  active      Boolean      @default(true)
  createdAt   DateTime     @default(now())
  redemptions Redemption[]
}

model Redemption {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id])
  rewardId      String
  reward        Reward    @relation(fields: [rewardId], references: [id])
  pointsCost    Int // captured at redemption time
  status        String    @default("requested") // requested | approved | fulfilled | cancelled
  fulfilledById String?
  fulfilledAt   DateTime?
  notes         String?
  createdAt     DateTime  @default(now())

  @@index([status])
}

/// Append-only. Wallet balance = SUM(amount) for a user. Never mutate/delete rows.
model RewardLedger {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  amount     Int // signed: + earned, - spent
  type       String // RECOGNITION | AWARD | REDEMPTION | EXPIRY | ADJUSTMENT
  sourceType String? // "recognition_recipient" | "nomination" | "redemption"
  sourceId   String?
  note       String?
  createdAt  DateTime @default(now())

  @@index([userId])
}

// ---------- Milestones ----------

model MilestoneRule {
  id     String  @id @default(cuid())
  type   String // "work_anniversary" | "birthday" | "onboarding"
  config Json // anniversaries -> { years: [1,3,5,10] }; onboarding -> { dayOffset: 30 }
  points Int     @default(0)
  active Boolean @default(true)
}

model Celebration {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  type          String
  occurredOn    DateTime
  recognitionId String? // the auto-post created on the feed
  createdAt     DateTime @default(now())

  @@unique([userId, type, occurredOn]) // idempotency guard for the cron
}

// ---------- Config ----------

model OrgSettings {
  id                      String  @id @default("singleton")
  appName                 String  @default("Applaud")
  monthlyAllowanceStaff   Int     @default(100)
  monthlyAllowanceManager Int     @default(200)
  pointsExpiryMonths      Int? // null = never expire
  allowSelfRecognition    Boolean @default(false)
}

// ---------- next-auth (Auth.js Prisma adapter) ----------

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
